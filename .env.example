APP_ENV=development
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# Required in production. Use long random values and keep them server-side only.
SECRET_KEY=
REFRESH_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=postgresql://coach:coach@localhost:5432/learning_coach
DB_ECHO=false
REDIS_URL=redis://localhost:6379/0
SHORT_TERM_MEMORY_TTL_SECONDS=86400
SHORT_TERM_MEMORY_EVENTS=30

COACH_LLM_API_KEY=
COACH_LLM_BASE_URL=https://api.deepseek.com
COACH_LLM_MODEL=deepseek-chat
COACH_LLM_TEMPERATURE=0.2
COACH_LLM_RETRY_ATTEMPTS=3
COACH_DATA_DIR=data

# Optional. Leave empty to use public GitHub API.
# Set this only on the backend/server for higher rate limits or authorized repository access.
GITHUB_TOKEN=
GITHUB_RETRY_ATTEMPTS=3
